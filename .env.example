# Copie para .env e preencha. NÃO comite o .env (já está no .gitignore).

# Chave do OpenRouter — OPCIONAL aqui: o ideal é o site mandar a chave do usuário
# no header X-OR-Key. Só preencha se quiser uma chave padrão no servidor.
OPENROUTER_API_KEY=

# Modelo padrão quando o site não especificar
DEFAULT_MODEL=openai/gpt-4.1-mini

# Domínios do site que podem chamar o backend (separados por vírgula).
# Ex.: https://victorold12.github.io,https://vtz-life-47067.web.app,http://localhost:8080
# Use * só em teste.
ALLOWED_ORIGINS=*

# --- Conectores (todos gratuitos) ---
# Notion — crie a integração em https://www.notion.so/my-integrations
NOTION_TOKEN=

# Figma — Settings > Personal access tokens (https://www.figma.com/developers/api#access-tokens)
FIGMA_TOKEN=

# Google (Gmail/Drive) — console.cloud.google.com > OAuth client (App da Web).
# Ative Gmail API e Drive API. Redirect abaixo deve estar autorizado no console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/connectors/google/callback

# MCP não precisa de chave aqui — o server_url vai na chamada /api/mcp/tools
